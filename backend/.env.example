PORT=3600
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000,https://your-store.vercel.app

DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASS=your-mysql-password
DB_NAME=shoplite
DB_SSL=true
DB_POOL_SIZE=10

JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
API_RATE_LIMIT=600
CONTACT_RATE_LIMIT=10

# Google OAuth client ID used by both backend and frontend.
GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Public API origin used to build uploaded image URLs.
PUBLIC_API_URL=http://localhost:3600
# Use persistent storage in production (for example /var/data/shoplite/uploads).
UPLOAD_DIR=./uploads

# Password reset and contact email
FRONTEND_URL=http://localhost:3000
JWT_RESET_SECRET=replace-with-another-long-random-secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_CONNECTION_TIMEOUT=8000
SMTP_GREETING_TIMEOUT=8000
SMTP_SOCKET_TIMEOUT=12000
MAIL_FROM=ShopLite <no-reply@shoplite.vn>
SUPPORT_EMAIL=support@shoplite.vn

# Recommended in production when the host blocks outbound SMTP ports.
RESEND_API_KEY=
RESEND_FROM=ShopLite <onboarding@resend.dev>

# Optional SMS gateway. ShopLite POSTs JSON {to, message, sender} to this URL.
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
SMS_SENDER=ShopLite

# VNPay 2.1.0. Use sandbox credentials while VNPAY_TEST_MODE=true.
VNPAY_TMN_CODE=your-vnpay-terminal-code
VNPAY_SECURE_SECRET=your-vnpay-secure-secret
VNPAY_HOST=https://sandbox.vnpayment.vn
VNPAY_TEST_MODE=true
# Must be a public backend URL registered with VNPay.
VNPAY_RETURN_URL=https://your-api-host.example/api/payments/vnpay/return
# Register this IPN URL in the VNPay merchant portal:
# https://your-api-host.example/api/payments/vnpay/ipn
